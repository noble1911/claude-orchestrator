{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Orchestrator",
  "version": "0.1.0",
  "identifier": "com.ron.claude-orchestrator",
  "build": {
    "beforeDevCommand": "cd mcp-permission-bridge && npm install --prefer-offline && npm run build && cd .. && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cd mcp-permission-bridge && npm run build && cd .. && npm run build:web && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Orchestrator",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../web/dist": "web-dist/",
      "../mcp-permission-bridge/dist": "mcp-permission-bridge/dist/"
    },
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/noble1911/claude-orchestrator/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4NzQ1RUM1MTA5RjA5RkUKUldUK0NaOFF4VjUwR1Ayd1UrYkZiZGxISi9zcDR6RTRoYjlVNjQ3eVdUMk9sUlpZVDY4MXNpOTQK"
    }
  }
}
